SOURCE_MODE=filesystem
FILESYSTEM_INPUT_DIR=examples/data
DATABASE_PATH=data/linkedin_alerts.sqlite3
OUTPUT_DIR=output
PROFILE_PATH=profile.json

# Gmail API mode
GMAIL_QUERY=from:(jobalerts-noreply@linkedin.com OR jobs-noreply@linkedin.com) newer_than:2d
GMAIL_LABEL_NAMES=LinkedIn Alerts
GMAIL_LABEL_IDS=
GMAIL_PROCESSED_LABEL_NAME=
GMAIL_CREATE_PROCESSED_LABEL=false
GMAIL_MAX_RESULTS=25
GMAIL_MARK_READ=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_CLIENT_SECRETS_PATH=secrets/google-oauth-client.json
GMAIL_TOKEN_PATH=secrets/google-token.json
GMAIL_REDIRECT_URI=http://127.0.0.1:8765/callback
GMAIL_AUTH_TIMEOUT_SECONDS=180

# Optional bearer-token fallback
GMAIL_ACCESS_TOKEN=

# Optional OpenAI enrichment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1/responses
OPENAI_REASONER_ENABLED=false

# Digest delivery
DIGEST_FROM_EMAIL=
DIGEST_TO_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
